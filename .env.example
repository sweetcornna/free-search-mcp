# free-search-mcp configuration — copy to `.env` and edit.
# Every setting is optional; the defaults below are the built-in ones.
# All variables are prefixed with SEARCH_MCP_.

# --- Engines -----------------------------------------------------------------
# JSON list. The default pool is the fast, all-HTTP, no-browser set.
# Opt-in extras (keyless): "startpage","searx","brave","bing","baidu",
#   "google","serpsearch","anysearch","bilibili","zhihu".
# Example enabling the newly added engines globally:
#   SEARCH_MCP_DEFAULT_ENGINES=["duckduckgo","mojeek","googlenews","anysearch","bilibili"]
SEARCH_MCP_DEFAULT_ENGINES=["duckduckgo","mojeek","googlenews"]
SEARCH_MCP_MAX_RESULTS_PER_ENGINE=10

# --- Rate limits (per minute) ------------------------------------------------
SEARCH_MCP_RATE_LIMIT_PER_MINUTE=30
SEARCH_MCP_FETCH_RATE_LIMIT_PER_MINUTE=20

# --- Cache -------------------------------------------------------------------
# SEARCH_MCP_CACHE_DIR=~/.cache/search-mcp
SEARCH_MCP_CACHE_TTL_SECONDS=604800   # 7 days

# --- Fetch / browser ---------------------------------------------------------
SEARCH_MCP_FETCH_STRATEGY=auto        # auto | http | browser
SEARCH_MCP_BROWSER_HEADLESS=true
SEARCH_MCP_BROWSER_POOL_SIZE=2
SEARCH_MCP_MAX_CONTENT_CHARS=50000
SEARCH_MCP_REQUEST_TIMEOUT=15.0
SEARCH_MCP_FETCH_TIMEOUT=25.0

# --- Locale ------------------------------------------------------------------
SEARCH_MCP_SAFESEARCH=moderate        # strict | moderate | off
SEARCH_MCP_REGION=us-en               # 'cc-lang' token, e.g. us-en, uk-en
SEARCH_MCP_ACCEPT_LANGUAGE=en-US,en;q=0.9

# --- API keys (keyed engines) ------------------------------------------------
# All keyless engines work with NO keys. These unlock the optional keyed
# engines. Easiest way to set them: run `uv run search-mcp-admin` and paste
# keys in the browser (stored at ~/.config/search-mcp/config.json, 0600).
# Setting them here as env vars works too and OVERRIDES the admin-saved values.
# See docs/API_KEYS.md for how to obtain each one.
# SEARCH_MCP_BRAVE_API_KEY=          # engine "brave_api"  — brave.com/search/api
# SEARCH_MCP_SERPER_API_KEY=         # engine "serper"     — serper.dev
# SEARCH_MCP_TAVILY_API_KEY=         # engine "tavily"     — app.tavily.com
# SEARCH_MCP_GOOGLE_CSE_API_KEY=     # engine "google_cse" — needs BOTH key …
# SEARCH_MCP_GOOGLE_CSE_CX=          #                       … and the cx (engine id)
# SEARCH_MCP_ANYSEARCH_API_KEY=      # optional — raises anysearch rate limits
# Where the admin UI stores keys, and the port it serves on:
# SEARCH_MCP_CONFIG_DIR=~/.config/search-mcp
# SEARCH_MCP_ADMIN_PORT=8765

# --- Proxy (fixes datacenter-IP CAPTCHA gating) ------------------------------
# Route outbound traffic (HTTP engines + browser + fetch) through a proxy so
# Google/Bing/Zhihu work from a non-blocked/residential IP. Also settable in the
# admin UI "Network / Proxy" card. http/https/socks5, optional user:pass@.
# SEARCH_MCP_PROXY=http://user:pass@host:port
# Optional: route ONLY these engines through the proxy (blank = all engines):
# SEARCH_MCP_PROXY_ENGINES=google bing zhihu

# --- Safety / sandbox --------------------------------------------------------
# Allow connecting to private/loopback/reserved IPs (SSRF guard escape hatch).
SEARCH_MCP_ALLOW_PRIVATE_HOSTS=false
# Enable local-file reads in read_doc by pointing this at a directory (opt-in).
# SEARCH_MCP_DOCUMENT_ROOT=/path/to/allowed/docs
SEARCH_MCP_MAX_RESPONSE_BYTES=25000000
SEARCH_MCP_MAX_PDF_PAGES=200
SEARCH_MCP_MAX_DOCUMENT_CHARS=2000000

SEARCH_MCP_LOG_LEVEL=INFO
